<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>India Weekly Portfolio Analysis</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #333; max-width: 900px; margin: 0 auto; padding: 20px; background-color: #f5f5f5;">

  <!-- Header -->
  <h1 style="color: #1f2937; margin-bottom: 8px;">India Weekly Portfolio Analysis (NSE)</h1>
  <div style="background-color: #fef3c7; padding: 16px; border-radius: 8px; margin-bottom: 24px; border-left: 4px solid #f59e0b;">
    <strong>Target Week:</strong> {{ target_week_start }} &rarr; {{ target_week_end }} &nbsp;|&nbsp;
    <strong>As-of Date:</strong> {{ as_of_date }} &nbsp;|&nbsp;
    <strong>Universe:</strong> {{ universe }}
  </div>

  <!-- AI Analysis Section -->
  <div style="margin-bottom: 24px; padding: 20px; background: linear-gradient(135deg, #059669 0%, #047857 100%); border-radius: 12px; color: white;">
    <h2 style="margin-top: 0; margin-bottom: 16px;">AI Analysis Summary</h2>

    {% if summary.para_1_portfolio_overview %}
    <div style="margin-bottom: 16px;">
      <h4 style="margin: 0 0 8px 0; opacity: 0.9;">1. Portfolio Overview</h4>
      <p style="font-size: 14px; line-height: 1.6; margin: 0;">{{ summary.para_1_portfolio_overview }}</p>
    </div>
    {% endif %}

    {% if summary.para_2_concentration_analysis %}
    <div style="margin-bottom: 16px; padding: 12px; background: rgba(255,255,255,0.1); border-radius: 8px;">
      <h4 style="margin: 0 0 8px 0;">2. Concentration Analysis</h4>
      <p style="font-size: 14px; line-height: 1.6; margin: 0;">{{ summary.para_2_concentration_analysis }}</p>
    </div>
    {% endif %}

    {% if summary.para_3_risk_observations %}
    <div>
      <h4 style="margin: 0 0 8px 0; opacity: 0.9;">3. Risk Observations</h4>
      <p style="font-size: 14px; line-height: 1.6; margin: 0;">{{ summary.para_3_risk_observations }}</p>
    </div>
    {% endif %}
  </div>

  <!-- HRP Allocation -->
  <div style="margin-bottom: 24px;">
    <h3 style="color: #374151; border-bottom: 2px solid #10b981; padding-bottom: 8px;">HRP Allocation (Risk-Balanced)</h3>
    <p style="color: #6b7280; font-size: 14px;">Symbols allocated: {{ hrp.symbols_used }} | Lookback: {{ hrp.lookback_days }} trading days | As-of: {{ hrp.as_of_date }}</p>
    <table style="width: 100%; border-collapse: collapse; font-size: 14px; margin-top: 12px;">
      <thead>
        <tr style="background-color: #f0fdf4;">
          <th style="padding: 10px 8px; text-align: left; border-bottom: 2px solid #10b981; width: 40px;">#</th>
          <th style="padding: 10px 8px; text-align: left; border-bottom: 2px solid #10b981;">Symbol</th>
          <th style="padding: 10px 8px; text-align: left; border-bottom: 2px solid #10b981;">Weight</th>
        </tr>
      </thead>
      <tbody>
        {% for sym, wt in hrp.percentage_weights.items() | sort(attribute='1', reverse=true) %}{% if wt > 0 %}
        <tr>
          <td style="padding: 6px 8px; border-bottom: 1px solid #e5e7eb;">{{ loop.index }}</td>
          <td style="padding: 6px 8px; border-bottom: 1px solid #e5e7eb; font-weight: bold;">{{ sym }}</td>
          <td style="padding: 6px 8px; border-bottom: 1px solid #e5e7eb;">
            <div style="display: flex; align-items: center; gap: 6px;">
              <div style="width: {{ (wt * 3) | int }}px; height: 12px; background: linear-gradient(90deg, #10b981, #34d399); border-radius: 3px;"></div>
              <span>{{ "%.1f" | format(wt) }}%</span>
            </div>
          </td>
        </tr>
        {% endif %}{% endfor %}
      </tbody>
    </table>
  </div>

  <!-- Footer -->
  <div style="margin-top: 32px; padding-top: 16px; border-top: 1px solid #e5e7eb; font-size: 12px; color: #6b7280;">
    <em>Generated by LearnFinance-2025 | HRP Risk Parity | NSE India | Nifty 500 Shariah | Not financial advice</em><br/>
    Run as-of: {{ as_of_date }}
  </div>

</body>
</html>

{% extends "alpha_hrp_email_base.html.j2" %}

{% block document_title %}US Alpha-HRP Portfolio Analysis{% endblock %}

{% block strategy_label %}US Alpha-HRP{% endblock %}

{# Header overrides the base to add the "(Alpaca Paper)" suffix on the
   title -- structural HTML (banner div, target-week chip) is inherited
   from the base. #}
{% block header_title %}US Alpha-HRP Portfolio Analysis (Alpaca Paper){% endblock %}

{% block skipped_notice %}
  <div style="margin-bottom: 24px; padding: 20px; background-color: #fef3c7; border-radius: 12px; border-left: 4px solid #f59e0b;">
    <h2 style="margin-top: 0; margin-bottom: 12px; color: #92400e;">Run Skipped</h2>
    <p style="margin: 0; color: #78350f;">
      US Alpha-HRP did not place new orders this week because the hrp Alpaca account
      still has open orders from a previous run. Cancel them in the Alpaca dashboard
      and rerun to refresh the alpha screen and HRP weights.
    </p>
  </div>
{% endblock %}

{% block order_execution_heading %}Alpaca Order Execution (hrp account, algorithm=alpha_hrp){% endblock %}
